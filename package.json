{
  "name": "cakkatrok-tiktok-downloader",
  "version": "1.0.0",
  "description": "TikTok video, photo slideshow, and MP3 downloader wrapper using SaveTik web endpoint.",
  "main": "index.js",
  "type": "commonjs",
  "bin": {
    "savetik-dl": "./bin/savetik-cli.js"
  },
  "scripts": {
    "test": "node --test",
    "start": "node bin/savetik-cli.js --help",
    "example:basic": "node examples/basic.js",
    "example:download": "node examples/download-all.js"
  },
  "keywords": [
    "tiktok",
    "downloader",
    "savetik",
    "mp4",
    "mp3",
    "photo",
    "slideshow"
  ],
  "author": "RintisW.P",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rintisdev20/cakkatrok-tiktok-downloader.git"
  },
  "bugs": {
    "url": "https://github.com/rintisdev20/cakkatrok-tiktok-downloader/issues"
  },
  "homepage": "https://github.com/rintisdev20/cakkatrok-tiktok-downloader#readme",
  "files": [
    "bin/",
    "src/",
    "examples/",
    "index.js",
    "README.md"
  ],
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0"
  }
}
